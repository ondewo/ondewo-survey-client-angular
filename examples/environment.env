# -----------------------------------------------------------------------------
# ONDEWO Survey Angular client SDK — examples configuration template.
#
# This is a NON-SECRET template. Copy the values a consuming application needs
# and supply them through its own configuration mechanism (Angular DI / build
# environment). Every field that would hold a secret is intentionally left
# blank — never commit real credentials.
#
# Variable names are the canonical ONDEWO scheme (one name per concept, shared
# across every ONDEWO client-SDK examples folder) so config stays consistent
# across services and languages.
# -----------------------------------------------------------------------------

# --- Connection -------------------------------------------------------------
ONDEWO_HOST=localhost
ONDEWO_PORT=50051

# --- Secure channel ---------------------------------------------------------
ONDEWO_USE_SECURE_CHANNEL=true
# Optional path to a gRPC TLS certificate file (leave blank to use system CAs).
ONDEWO_GRPC_CERT=

# --- Basic auth -------------------------------------------------------------
ONDEWO_USER_NAME=
ONDEWO_PASSWORD=
ONDEWO_HTTP_BASIC_AUTH_TOKEN=

# --- Keycloak (bearer-token / 2FA auth) -------------------------------------
KEYCLOAK_URL=https://auth.example.com/auth
KEYCLOAK_REALM=ondewo-ccai-platform
KEYCLOAK_CLIENT_ID=ondewo-nlu-cai-sdk-public
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_USER_NAME=
KEYCLOAK_PASSWORD=
KEYCLOAK_VERIFY_SSL=true

# --- Survey service-specific ------------------------------------------------
# Id of the survey the examples read via SurveysClient.getSurvey(...).
ONDEWO_SURVEY_ID=
